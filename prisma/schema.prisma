generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Anchor table until engagement-centric models (`engagement_id`, `metric_snapshots`, etc.) are added.
model AppMeta {
  key   String  @id
  value String?
}

model Client {
  id          String            @id @default(cuid())
  clientCode  String            @unique
  companyName String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users       ClientUser[]
  submissions ModelSubmission[]
  metrics     MetricSnapshot[]
}

model ModelSubmission {
  id           String           @id @default(cuid())
  clientId     String
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateId   String
  fileName     String
  filePath     String
  fileSize     Int
  status       String           @default("uploaded")
  uploadedById String
  parsedData   Json?
  parsedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  metrics      MetricSnapshot[]

  @@unique([clientId, templateId])
}

model ClientUser {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clientId, email])
}

model MetricSnapshot {
  id           String          @id @default(cuid())
  submissionId String
  submission   ModelSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateId   String
  sheetName    String
  section      String
  metricKey    String
  label        String
  numericValue Float?
  textValue    String?
  period       String?
  unit         String?
  createdAt    DateTime        @default(now())

  @@index([clientId, templateId])
  @@index([metricKey])
}
