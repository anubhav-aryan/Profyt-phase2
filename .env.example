# Auth — same Google OAuth client as Phase 1 (add Phase 2 `/api/auth/callback/google` to redirect URIs)
AUTH_SECRET=
# Optional alias accepted by some tooling
NEXTAUTH_SECRET=

# NextAuth URLs (required for production deployment)
# Set to your main domain (not the Vercel deployment URL)
NEXTAUTH_URL=https://www.profyt.in
# Internal URL for Vercel deployment (can be different from NEXTAUTH_URL)
# NEXTAUTH_URL_INTERNAL=https://profyt-phase2.vercel.app

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MongoDB (Phase 1 cluster) — sign-in allowlist checks collection `clientprofiles` by email
MONGODB_URI=

# Optional: only if Atlas collection names differ from Mongoose defaults (leakagesubmissions / scalerisksubmissions)
# MONGODB_LEAKAGE_COLLECTION=
# MONGODB_SCALERISK_COLLECTION=

# Optional: comma-separated emails allowed without a ClientProfile document (internal analysts)
AUTH_BYPASS_EMAILS=

# Superadmin (Google sign-in): comma-separated emails that may access /admin and /api/admin
SUPERADMIN_EMAILS=

# Neon PostgreSQL — Prisma CLI does not load `.env.local` by default; use `npm run db:deploy`
# (loads `.env` then `.env.local`) or put `DATABASE_URL` in a root `.env` file.
DATABASE_URL=

# Optional: after migrations, seed demo portal login — Client ID `demo-client`, user `demo-user`, password `profyt`
# npm run db:seed
