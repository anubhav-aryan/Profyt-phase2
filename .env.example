# Auth — same Google OAuth client as Phase 1 (add Phase 2 `/api/auth/callback/google` to redirect URIs)
AUTH_SECRET=
# Optional alias accepted by some tooling
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MongoDB (Phase 1 cluster) — sign-in allowlist checks collection `clientprofiles` by email
MONGODB_URI=

# Optional: comma-separated emails allowed without a ClientProfile document (internal analysts)
AUTH_BYPASS_EMAILS=

# Neon PostgreSQL — Prisma CLI does not load `.env.local` by default; use `npm run db:deploy`
# (loads `.env` then `.env.local`) or put `DATABASE_URL` in a root `.env` file.
DATABASE_URL=
